        st.code(traceback.format_exc())
        return

    # Sortierung
    if sort_by == "Priorität":
        emails = sorted(emails, key=lambda x: x['analysis']['priority'], reverse=True)
    elif sort_by == "Datum":
        emails = sorted(emails, key=lambda x: x['email'].get('receivedDateTime', ''), reverse=True)
    elif sort_by == "Absender":
        emails = sorted(emails, key=lambda x: x['email'].get('from', {}).get('emailAddress', {}).get('name', ''))

    # Stats anzeigen
    total = len(emails)
    high_priority = len([e for e in emails if e['analysis']['priority'] >= 4])

