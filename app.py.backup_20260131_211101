            st.markdown("💡 Der Background Worker analysiert neue E-Mails automatisch alle 2 Minuten.")
            return

        # Konvertiere DB-Format zu UI-Format
        emails = []
        for email_db in emails_db:
            # Rekonstruiere Email-Dict
            email = {
                'id': email_db['message_id'],
                'subject': email_db['subject'],
                'from': {
                    'emailAddress': {
                        'name': email_db['sender_name'],
                        'address': email_db['sender_email']
                    }
                },
                'receivedDateTime': email_db['received_at'],
                'bodyPreview': email_db['body_preview'],
                'body': {'content': email_db['body_full']},  # Vollständiger Body für Antworten
                'hasAttachments': bool(email_db['has_attachments']),
                'webLink': email_db['web_link']
            }

            # Analysis-Dict
            analysis = {
                'priority': email_db['priority'],
                'category': email_db['category'],
                'summary': email_db['summary'],
                'sentiment': email_db['sentiment'],
                'action_items': email_db['action_items'],
                'deadline': email_db['deadline']
            }

            # Suggested Project
            suggested_project = None
            if email_db['suggested_board_gid']:
                suggested_project = {
                    'project_gid': email_db['suggested_board_gid'],
                    'project_name': email_db['suggested_board_name'],
                    'confidence': email_db['suggestion_confidence'],
                    'reason': email_db['suggestion_reason']
                }

            # Forwarding Rule (aus Config laden)
            forwarding_rule = st.session_state.email_manager.get_forwarding_rule(analysis['category'])

            emails.append({
                'email': email,
                'analysis': analysis,
                'suggested_project': suggested_project,
                'forwarding_rule': forwarding_rule,
                'db_id': email_db['id'],  # Wichtig für Action-Queue
                'status': email_db.get('status', 'analyzed')  # Email-Status aus DB
