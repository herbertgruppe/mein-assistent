                    for e in selectable_emails:
                        st.session_state.selected_emails.discard(e['db_id'])
                else:
                    # Selektiere alle
                    for e in selectable_emails:
                        st.session_state.selected_emails.add(e['db_id'])
                st.rerun()

    st.divider()

    # Email-Karten rendern
    for idx, item in enumerate(emails):
        render_email_card(
            item['email'],
            item['analysis'],
            item['suggested_project'],
            item['forwarding_rule'],
            idx,
            st.session_state.email_manager,
            item.get('db_id'),  # Übergebe DB-ID für Action-Queue
            item.get('status', 'analyzed'),  # Übergebe Status
            all_asana_projects  # Übergebe Asana-Projekte (einmal geladen!)
        )


def render_email_card(email: Dict[str, Any], analysis: Dict[str, Any],
                     suggested_project: Optional[Dict[str, Any]],
                     forwarding_rule: Optional[Dict[str, Any]],
                     idx: int, email_manager, email_db_id: Optional[int] = None,
                     email_status: str = 'analyzed',
                     all_asana_projects: List[Dict[str, Any]] = []):
    """
    Rendert eine einzelne E-Mail-Karte

    Args:
        email: Email-Dict
        analysis: Analysis-Dict
        suggested_project: Suggested Asana Project
        forwarding_rule: Forwarding Rule
        idx: Index für unique keys
        email_manager: EmailManager Instanz
        email_db_id: Optional DB-ID für Action-Queue
        email_status: Status der Email (analyzed, pending_*, archived)
        all_asana_projects: Liste aller Asana-Projekte (einmal geladen)
    """
    # Extrahiere Daten
    subject = email.get('subject', 'Kein Betreff')
    sender_name = email.get('from', {}).get('emailAddress', {}).get('name', 'Unbekannt')
    sender_email = email.get('from', {}).get('emailAddress', {}).get('address', '')
    received_dt = email.get('receivedDateTime', '')
    body_preview = email.get('bodyPreview', '')
    has_attachments = email.get('hasAttachments', False)

    # Formatiere Datum
    try:
        received_datetime = datetime.fromisoformat(received_dt.replace('Z', '+00:00'))
        date_str = received_datetime.strftime('%d.%m.%Y %H:%M')
    except:
        date_str = received_dt

    # Prioritäts-Badge
    priority = analysis.get('priority', 3)
    priority_badges = {
        5: "🔴 Kritisch",
        4: "🟠 Dringend",
        3: "🟡 Normal",
        2: "🟢 Niedrig",
        1: "⚪ Sehr niedrig"
    }
    priority_badge = priority_badges.get(priority, "🟡 Normal")

    # Sentiment-Emoji
    sentiment = analysis.get('sentiment', 'neutral')
    sentiment_emojis = {
        'positiv': '😊',
        'neutral': '😐',
        'negativ': '😟',
        'dringend': '⚡'
    }
    sentiment_emoji = sentiment_emojis.get(sentiment, '😐')

    # Card Container mit CSS-Styling
    priority_colors = {
        5: "#ffebee",  # Rot
        4: "#fff3e0",  # Orange
        3: "#f5f5f5",  # Grau
        2: "#e8f5e9",  # Grün
        1: "#fafafa"   # Sehr hell
    }
    bg_color = priority_colors.get(priority, "#f5f5f5")

    with st.container():
        st.markdown(
            f"""
            <div style="padding: 1rem; background-color: {bg_color}; border-radius: 0.5rem;
                        border-left: 4px solid {'#d32f2f' if priority >= 4 else '#757575'};
                        margin-bottom: 1rem;">
            </div>
            """,
            unsafe_allow_html=True
        )

        # Status-Badge (falls pending)
        status_badges = {
            'pending_asana': '⏳ An Asana senden...',
            'pending_forward': '⏳ Wird weitergeleitet...',
            'pending_reply': '⏳ Antwort wird gesendet...',
            'pending_archive': '⏳ Wird archiviert...'
        }
        is_pending = email_status.startswith('pending_')
        status_badge = status_badges.get(email_status, '')

        # Checkbox für Bulk-Selektion + Header
        if is_pending:
            colcheck, col1, col2, col3, col4 = st.columns([0.3, 2.2, 1, 1, 1.5])
        else:
            colcheck, col1, col2, col3, col4 = st.columns([0.3, 2.7, 1, 1, 0.1])

        with colcheck:
            # Checkbox nur wenn nicht pending
            if not is_pending and email_db_id:
                is_selected = email_db_id in st.session_state.selected_emails
                if st.checkbox("", value=is_selected, key=f"check_{idx}_{email_db_id}", label_visibility="collapsed"):
                    st.session_state.selected_emails.add(email_db_id)
                else:
                    st.session_state.selected_emails.discard(email_db_id)

        with col1:
            st.markdown(f"### {subject}")
        with col2:
            st.markdown(f"**{priority_badge}**")
        with col3:
            st.markdown(f"**{sentiment_emoji} {sentiment.title()}**")
        with col4:
            if is_pending:
                st.info(status_badge)

        # Meta: Absender + Datum + Attachments
        col1, col2 = st.columns([2, 1])
        with col1:
            st.markdown(f"**Von:** {sender_name} `<{sender_email}>`")
        with col2:
            attachments_text = "📎 Anhänge" if has_attachments else ""
            st.markdown(f"**{date_str}** {attachments_text}")

        # Kategorie
        category = analysis.get('category', 'Sonstiges')
        st.markdown(f"**Kategorie:** {category}")

        # Expander: Zusammenfassung & Details
        with st.expander("📝 Zusammenfassung & Details anzeigen"):
            summary = analysis.get('summary', 'Keine Zusammenfassung verfügbar')
            st.markdown(f"**Zusammenfassung:** {summary}")

            action_items = analysis.get('action_items', [])
            if action_items:
                st.markdown("**Handlungspunkte:**")
                for item in action_items:
                    st.markdown(f"- {item}")

            deadline = analysis.get('deadline')
            if deadline:
                st.markdown(f"**Deadline:** {deadline}")

            st.markdown("**E-Mail-Vorschau:**")
            st.text(body_preview[:300] + '...' if len(body_preview) > 300 else body_preview)

        # Asana-Vorschlag anzeigen
        if suggested_project:
            confidence = suggested_project.get('confidence', 0)
            project_name = suggested_project.get('project_name', 'Unbekannt')
            reason = suggested_project.get('reason', '')

            st.info(
                f"💡 **Vorgeschlagen:** {project_name} "
                f"(Konfidenz: {confidence:.0%}, {reason})"
            )

        # Action Buttons
        col1, col2, col3, col4, col5 = st.columns(5)

        with col1:
            # Asana-Projekt-Selectbox + Button (Projekte bereits geladen!)
            if all_asana_projects:
                try:
                    project_names = [p['name'] for p in all_asana_projects]
                    project_gids = {p['name']: p['gid'] for p in all_asana_projects}

                    # Default: Vorgeschlagenes Projekt
                    default_idx = 0
                    if suggested_project and suggested_project.get('project_name') in project_names:
                        default_idx = project_names.index(suggested_project['project_name'])

                    selected_project = st.selectbox(
                        "Asana-Projekt",
                        project_names,
                        index=default_idx,
                        key=f"proj_{idx}",
                        disabled=is_pending
                    )

                    if st.button("📤 An Asana senden", key=f"asana_{idx}", use_container_width=True, disabled=is_pending):
                        # Queue Action (instant, kein Blocking)
                        if email_db_id:
                            from utils.database import EmailDatabase
                            db = EmailDatabase()

                            # Erstelle Action in Queue
                            db.create_action(email_db_id, 'asana', {
                                'project_gid': project_gids[selected_project],
                                'project_name': selected_project
                            })

                            # Update Email Status
                            db.update_email_status(email_db_id, 'pending_asana')

                            # Cache invalidieren
                            load_emails_from_database.clear()

                            st.success(f"✅ Aufgabe wird im Hintergrund an '{selected_project}' gesendet...")
                            time.sleep(0.5)
                            st.rerun()
                        else:
                            st.error("❌ Email DB-ID fehlt (Legacy-Modus nicht unterstützt)")

                except Exception as e:
                    st.error(f"❌ Fehler: {e}")
            else:
                st.warning("⚠️ Asana-Projekte nicht verfügbar")

        with col2:
            # Weiterleiten mit Chat
            if st.button("↗️ Weiterleiten", key=f"fwd_{idx}", use_container_width=True, disabled=is_pending):
                # Öffne Email-Chat für Weiterleitung
                st.session_state.email_chat_active = True
                st.session_state.email_chat_data = {
                    'action_type': 'forward',
                    'email_id': email.get('id'),
                    'email_db_id': email_db_id,
                    'subject': subject,
                    'sender': f"{sender_name} <{sender_email}>",
                    'body': email.get('body', {}).get('content', body_preview),
                    'forwarding_rule': forwarding_rule  # Optional: für Vorschläge
                }
                st.session_state.email_chat_history = []
                st.rerun()

        with col3:
            # Antworten mit Chat
            if st.button("✉️ Antworten", key=f"reply_{idx}", use_container_width=True, disabled=is_pending):
                # Öffne Email-Chat für Antwort
                st.session_state.email_chat_active = True
                st.session_state.email_chat_data = {
                    'action_type': 'reply',
                    'email_id': email.get('id'),
                    'email_db_id': email_db_id,
                    'subject': subject,
                    'sender': f"{sender_name} <{sender_email}>",
                    'body': email.get('body', {}).get('content', body_preview)
                }
                st.session_state.email_chat_history = []
                st.rerun()

        with col4:
            # Archivieren
            if st.button("🗄️ Archivieren", key=f"arch_{idx}", use_container_width=True, disabled=is_pending):
                # Queue Action
                if email_db_id:
                    from utils.database import EmailDatabase
                    db = EmailDatabase()

                    db.create_action(email_db_id, 'archive', {})
                    db.update_email_status(email_db_id, 'pending_archive')  # Wird zu 'archived' nach Verarbeitung

                    # Cache invalidieren
                    load_emails_from_database.clear()

                    st.success("✅ Email wird archiviert...")
                    time.sleep(0.5)
                    st.rerun()
                else:
                    st.error("❌ Email DB-ID fehlt")

        with col5:
            # Als gelesen markieren (direkt, da schnell)
            if st.button("✓ Als gelesen", key=f"read_{idx}", use_container_width=True, disabled=is_pending):
                # Diese Action ist so schnell, dass wir sie direkt ausführen können
                # Optional: Auch in Queue setzen für Retry-Logic
                if email_db_id:
                    from utils.database import EmailDatabase
                    db = EmailDatabase()

                    db.create_action(email_db_id, 'mark_read', {})

                    # Cache invalidieren
                    load_emails_from_database.clear()

                    st.success("✅ Wird als gelesen markiert...")
                    time.sleep(0.3)
                    st.rerun()
                else:
                    st.error("❌ Email DB-ID fehlt")

        st.markdown("---")


def render_transcripts_tab():
    """
    Rendert den Meeting Manager Tab - nur Nachbereitung (Vorbereitung ist jetzt in "Mein Tag")
    """
    st.header("🎙️ Meeting Manager - Nachbereitung")

    st.markdown("""
    Der Meeting Manager hilft bei der **Nachbereitung** von Meetings durch
    automatische Protokoll-Erstellung und Task-Extraktion aus Transkripten.

    💡 **Hinweis:** Die Meeting-Vorbereitung findest du jetzt im Tab **"Mein Tag"**.
    """)

    st.markdown("---")

    # Transkript-Analyse Bereich
    st.markdown("### 🔍 Transkript analysieren & Tasks extrahieren")

    # Transkript-Upload Bereich
    uploaded_file = st.file_uploader(
        "📤 Transkript hochladen",
        type=['txt', 'md', 'pdf'],
        help="Lade ein Meeting-Transkript hoch (TXT, MD oder PDF)"
    )

    processed_dir = Path("transcripts/processed")
    processed_dir.mkdir(parents=True, exist_ok=True)

    # Verarbeite hochgeladenes File
    if uploaded_file is not None:
        # Speichere Datei
        file_path = processed_dir / uploaded_file.name
        with open(file_path, 'wb') as f:
            f.write(uploaded_file.getbuffer())
        st.success(f"✓ Datei gespeichert: {uploaded_file.name}")

    # Finde neueste Transkript-Datei
    processed_files = sorted(
        list(processed_dir.glob("*.txt")) + list(processed_dir.glob("*.md")) + list(processed_dir.glob("*.pdf")),
        key=lambda f: f.stat().st_mtime,
        reverse=True
    )

    if not processed_files:
        st.info("Keine verarbeiteten Transkripte gefunden. Lade ein Transkript hoch.")
    else:
        # Zeige neueste Datei
        latest_file = processed_files[0]
        st.info(f"📄 Neustes Transkript: **{latest_file.name}**")

        # TAGESNAVIGATION FÜR TERMIN-AUSWAHL
        st.markdown("---")
        st.markdown("### 📅 Termin auswählen")

        # Initialisiere Datum im Session State
        if 'meeting_date_selection' not in st.session_state:
            # Versuche Datum aus Transkript-Dateiname zu extrahieren
            from meeting_manager import MeetingManager
            mm = MeetingManager()
            transcript_dt, _ = mm.get_transcript_datetime(latest_file)
            st.session_state['meeting_date_selection'] = transcript_dt.date() if transcript_dt else datetime.now().date()

        # Tagesnavigation
        col_prev, col_date, col_next = st.columns([1, 3, 1])

        with col_prev:
            if st.button("◀ Vorheriger Tag"):
                st.session_state['meeting_date_selection'] -= timedelta(days=1)
                st.rerun()

        with col_date:
            selected_date = st.date_input(
                "Datum des Meetings:",
                value=st.session_state['meeting_date_selection'],
                key="meeting_date_picker"
            )
            if selected_date != st.session_state['meeting_date_selection']:
                st.session_state['meeting_date_selection'] = selected_date
                st.rerun()

        with col_next:
            if st.button("Nächster Tag ▶"):
                st.session_state['meeting_date_selection'] += timedelta(days=1)
                st.rerun()

        # Lade Termine für gewählten Tag
        orch = st.session_state.get('orchestrator')
        if not orch:
            st.warning("Orchestrator nicht initialisiert. Bitte App neu laden.")
            return

        outlook_tool = orch.outlook_tool
        day_events = []

        if outlook_tool.is_configured and outlook_tool.access_token:
            try:
                # Konvertiere date zu datetime
                start_of_day = datetime.combine(st.session_state['meeting_date_selection'], datetime.min.time())
                end_of_day = datetime.combine(st.session_state['meeting_date_selection'], datetime.max.time())

                day_events = outlook_tool.get_events_for_date_range(start_of_day, end_of_day)

                if day_events:
                    st.success(f"✓ {len(day_events)} Termin(e) am {st.session_state['meeting_date_selection'].strftime('%d.%m.%Y')} gefunden")
                else:
                    st.info(f"Keine Termine am {st.session_state['meeting_date_selection'].strftime('%d.%m.%Y')} gefunden")
            except Exception as e:
                st.warning(f"⚠️ Fehler beim Laden der Termine: {e}")
        else:
            st.warning("⚠️ Outlook nicht authentifiziert. Bitte im Sidebar einloggen.")

        # Termin-Auswahl
        if day_events:
            event_options = ["Kein Termin zuordnen"]
            event_dict = {}

            for event in day_events:
                event_start = event.get('start')
                event_title = event.get('title', 'Ohne Titel')

                # Parse Zeit
                if isinstance(event_start, str):
                    try:
                        event_start_dt = datetime.fromisoformat(event_start.replace('Z', '+00:00'))
