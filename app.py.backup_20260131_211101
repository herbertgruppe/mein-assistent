                            tool_result = tool_func.invoke(tool_args)

                            st.session_state['asana_chat_messages'].append({
                                'role': 'tool',
                                'content': tool_result,
                                'tool_call_id': tool_call.get('id')
                            })

                            tool_messages.append(ToolMessage(
                                content=tool_result,
                                tool_call_id=tool_call.get('id')
                            ))

                    # Follow-up Antwort
