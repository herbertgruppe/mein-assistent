                            meeting_title = latest_file.stem.split('_', 1)[-1] if '_' in latest_file.stem else latest_file.stem

                            # Ermittle passenden Outlook-Termin ZUERST (für Teilnehmer)
                            from meeting_manager import MeetingManager
