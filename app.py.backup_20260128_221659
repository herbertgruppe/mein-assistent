                            selected_event = None
                            attendees = None
                            meeting_date = None

                            if outlook_tool.is_configured and outlook_tool.access_token:
                                try:
                                    start_of_day = transcript_dt.replace(hour=0, minute=0, second=0, microsecond=0)
                                    end_of_day = transcript_dt.replace(hour=23, minute=59, second=59, microsecond=999999)
                                    day_events = outlook_tool.get_events_for_date_range(start_of_day, end_of_day)

                                    # Finde besten Match (zeitlich am nächsten)
                                    selected_event = mm.find_meeting_at_time(transcript_dt)

                                    # Extrahiere Teilnehmer aus Outlook-Termin
                                    if selected_event and selected_event.get('attendees'):
                                        attendees = [att.get('name', att.get('email', '')) for att in selected_event['attendees']]

                                    # Extrahiere Datum
                                    if selected_event and selected_event.get('start'):
                                        meeting_date = selected_event['start'].strftime('%d.%m.%Y %H:%M')
                                    elif transcript_dt:
                                        meeting_date = transcript_dt.strftime('%d.%m.%Y %H:%M')
                                except:
                                    pass

                            # Extrahiere Protokoll (mit Outlook-Teilnehmern)
                            with st.spinner("Erstelle strukturiertes Protokoll..."):
                                protocol_text = extract_protocol_from_transcript(
                                    transcript_text,
                                    meeting_title,
                                    llm,
                                    attendees=attendees,
                                    meeting_date=meeting_date
                                )

                            # Extrahiere Tasks
                            with st.spinner("Extrahiere Aufgaben..."):
                                tasks = extract_tasks_from_transcript(transcript_text, llm)

                            # Speichere in Session State
                            st.session_state['extracted_protocol'] = protocol_text
                            st.session_state['extracted_tasks'] = tasks if tasks else []
                            st.session_state['transcript_source'] = latest_file.name
                            st.session_state['meeting_title'] = meeting_title
                            st.session_state['transcript_datetime'] = transcript_dt
                            st.session_state['day_events'] = day_events
                            st.session_state['selected_event'] = selected_event

