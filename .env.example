# LLM Provider Auswahl (anthropic oder openai)
LLM_PROVIDER=anthropic

# API Keys (abhängig vom gewählten Provider)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Modell-Konfiguration
# RESEARCH_MODEL wird vom ResearchAgent (LLM für Protokoll-Erzeugung + Task-Extraktion) gelesen.
# Default ist Haiku 4.5 (schnell, günstig, qualitativ ausreichend für strukturierte Protokoll-/Task-Outputs).
# Alternativen: claude-sonnet-4-5 (höhere Qualität, langsamer), claude-opus-4-5 (beste Qualität, teuer).
RESEARCH_MODEL=claude-haiku-4-5

# Legacy-Variablen — werden aktuell nicht aktiv gelesen, behalten für Rückwärtskompatibilität.
ANTHROPIC_MODEL=claude-haiku-4-5

# OpenAI Models: gpt-4, gpt-4-turbo-preview, gpt-3.5-turbo
OPENAI_MODEL=gpt-4

# Weitere Konfigurationen
TEMPERATURE=0.7

# Tavily API für Web-Suche (optional)
TAVILY_API_KEY=your-tavily-api-key-here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OUTLOOK E-MAIL KONFIGURATION (CommunicationAgent)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Option 1: SMTP mit App-Passwort (Einfacher)
# Erstelle ein App-Passwort unter: https://account.microsoft.com/security
OUTLOOK_EMAIL=deine-email@herbert.de
OUTLOOK_PASSWORD=dein-app-passwort-hier

# Option 2: Microsoft Graph API (Für Business-Konten ohne App-Passwort)
# Registriere eine App in Azure Portal: https://portal.azure.com
# Siehe agents/communication_agent.py für vollständige Setup-Anleitung
GRAPH_CLIENT_ID=deine-client-id
GRAPH_CLIENT_SECRET=dein-client-secret
GRAPH_TENANT_ID=deine-tenant-id

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# REST-API (api.py) — Endpoint /api/process-reviewed-protocol
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Geheimer API-Key für den Cowork-Skill `meeting-protokoll`.
# Generierung (lokal):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Wird vom Cowork-Skill als HTTP-Header übergeben:
#   X-API-Key: <wert>
API_SECRET_KEY=hier-zufallsstring-mit-mindestens-32-zeichen-eintragen

# Trusted Proxies für Authentik-Header (X-Authentik-Username, X-Forwarded-Email).
# Nur Anfragen von diesen IPs dürfen Proxy-Header setzen. nginx läuft auf 127.0.0.1,
# daher ist das der richtige Default. Mehrere IPs kommasepariert.
TRUSTED_PROXIES=127.0.0.1

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TELEGRAM-BRIDGE (HBE-402 / HBE-1421) — PA-Registry
#
# Es gibt zwei Wege, PAs zu registrieren:
#
# 1. Legacy-Vars (Lena & Mara — bestehende Produktions-Deployments):
#    TELEGRAM_BOT_TOKEN / TELEGRAM_WEBHOOK_SECRET / TELEGRAM_ADMIN_CHAT_ID → slug "lena"
#    TELEGRAM_MARA_BOT_TOKEN / TELEGRAM_MARA_WEBHOOK_SECRET / ... → slug "mara"
#
# 2. Neue Generisch-Vars (HBE-1421) — neue PAs mit 3 Env-Vars konfigurierbar:
#    TELEGRAM_AGENT_{SLUG}_TOKEN=<bot-token>
#    TELEGRAM_AGENT_{SLUG}_WEBHOOK_SECRET=<secret>
#    TELEGRAM_AGENT_{SLUG}_PAPERCLIP_AGENT_ID=<agent-uuid>
#    Optional: TELEGRAM_AGENT_{SLUG}_ADMIN_CHAT_ID=<chat-id>
#
# Neue Endpoints (HBE-1421):
#   POST /api/telegram/{slug}/webhook   → eingehende Telegram-Updates
#   POST /api/telegram/{slug}/send      → ausgehende Nachricht senden
# Backward-Compat-Aliases bleiben bestehen:
#   POST /api/lena/telegram/send  →  /api/telegram/lena/send
#   POST /api/mara/telegram/send  →  /api/telegram/mara/send
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Lena (Legacy) ────────────────────────────────────
# Bot-Token von @BotFather (Format: 123456:ABC-DEF...)
TELEGRAM_BOT_TOKEN=

# Secret-Token für Webhook-Verifikation (X-Telegram-Bot-Api-Secret-Token Header).
# Generierung: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Beim Webhook-Register mitgeben: -d "secret_token=<wert>"
TELEGRAM_WEBHOOK_SECRET=

# Paperclip API-Credentials für mein-assistent (externes Service-Account-Token).
# Alle Werte aus dem Paperclip-Dashboard oder via `paperclipai` CLI.
PAPERCLIP_API_URL_MA=https://paperclip.herbertgruppe.com
PAPERCLIP_COMPANY_ID_MA=9df4976b-9ac8-4e8f-a156-c06c7fa40cdc
PAPERCLIP_API_KEY_MA=<pcp_... token from Paperclip — run: paperclipai agent local-cli lena --key-name mein-assistent-service>
PAPERCLIP_LENA_AGENT_ID=7517114f-e731-4df5-96cf-a044719e9318

# Svens Telegram-Chat-ID (empfaengt Speaker-Rueckfragen von Mara).
# Ermittlung: @userinfobot in Telegram anschreiben, oder in den Logs nach
# "Telegram webhook" suchen und die chat_id aus dem ersten Webhook-Aufruf ablesen.
TELEGRAM_ADMIN_CHAT_ID=

# SKILL_SPEAKER Fallback-Verhalten wenn Speaker nach Outlook-Abgleich unklar.
# ask     — immer Telegram-Frage mit Buttons senden (Default, empfohlen)
# continue — automatisch Protokoll mit Unbekannter-Sprecher-Platzhaltern erstellen
# pause   — automatisch Issue auf blocked setzen ohne Telegram-Frage
MARA_SPEAKER_FALLBACK_DEFAULT=ask

# ── Mara (Legacy) ────────────────────────────────────
TELEGRAM_MARA_BOT_TOKEN=
TELEGRAM_MARA_WEBHOOK_SECRET=
PAPERCLIP_MARA_AGENT_ID=
TELEGRAM_MARA_ADMIN_CHAT_ID=

# ── Beispiel: neue PA "anna" via generische Vars (HBE-1421) ──
# TELEGRAM_AGENT_ANNA_TOKEN=123456:ABC-DEF...
# TELEGRAM_AGENT_ANNA_WEBHOOK_SECRET=<python -c "import secrets; print(secrets.token_urlsafe(32))">
# TELEGRAM_AGENT_ANNA_PAPERCLIP_AGENT_ID=<uuid aus Paperclip-Dashboard>
# TELEGRAM_AGENT_ANNA_ADMIN_CHAT_ID=   # optional

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SMTP KONFIGURATION (api.py — /api/lena/send-mail)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SMTP_USER=your-smtp-username
SMTP_FROM=your-sender@example.com
SMTP_PASSWORD=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# VAULT-SYNC-PIPELINE (HBE-757) — Lena schreibt Svens Obsidian-Vault
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Bind-Mount-Pfad des Vault-Mirrors auf dem Host (in docker-compose.yml gemountet)
VAULT_MIRROR_PATH=/opt/vault-mirror
# GitHub Fine-Grained PAT — NUR für herbertgruppe/vault-memory, Scope: Contents: Read+Write.
# KEIN org-weiter Token (GITHUB_ORG_TOKEN). Separaten PAT für vault-memory ausstellen:
#   GitHub → Settings → Developer settings → Fine-grained tokens → Generate new token
#   Repository access: nur herbertgruppe/vault-memory
#   Permissions: Contents → Read and Write
GITHUB_BOT_TOKEN=ghp_...
# Audit-Log-Pfad (im data-Volume, damit er Docker-Rebuilds überlebt)
VAULT_AUDIT_LOG=/app/data/vault-lena.log
